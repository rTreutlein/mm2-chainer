; Transitive chain demo.
; A deep forward chain: Dog -> Mammal -> Animal -> Creature.
; STVs decrease at each hop so the final fact reflects the propagated values.

; Seed

; Rules
(ruleN (Mammal $x) 0.9 0.9 (pcons (Dog $x) pnil))
(ruleN (Animal $x) 0.8 0.8 (pcons (Mammal $x) pnil))
(ruleN (Creature $x) 0.7 0.7 (pcons (Animal $x) pnil))
(, (Goal (Creature x)))
(goal-path (Creature x) pnil)
(fact (Dog x) (1.0 1.0))
