; Transitive chain demo.
; A deep forward chain: Dog -> Mammal -> Animal -> Creature.
; STVs decrease at each hop so the final fact reflects the propagated values.

; Seed

; Rules
(ruleN (Mammal $x) (ctv (0.9 0.9) (0.0 1.0)) (pcons (Dog $x) pnil))
(ruleN (Animal $x) (ctv (0.8 0.8) (0.0 1.0)) (pcons (Mammal $x) pnil))
(ruleN (Creature $x) (ctv (0.7 0.7) (0.0 1.0)) (pcons (Animal $x) pnil))
(, (Goal (Creature x)))
(goal-path (Creature x) pnil)
(fact (Dog x) (1.0 1.0))
