; generated from PeTTaChainer tests/test_benchgen_metta.metta by convert_petta_tests.py
; benchmark-generator helper-state coverage; assertions run against PeTTa helper/compiler state
!(import! &self /nexus/Dev/OpenCog/NL2PLN_Project/mm2-chainer/compiler/mm2_chainer)
!(mm2-init)
!(import! &self /nexus/Dev/OpenCog/NL2PLN_Project/PeTTaChainer/pettachainer/metta/benchmarks/benchgen_metta)
!(BenchGenerate benchCore (depth 2) (width 2) (paths 1) (noise-factor 0) (backward-ratio 50) (backward-chain-len 3) (forward-chain-len 2))
!(mm2-test-equal (== (BenchBaseFactCount benchCore) 4) true)
!(mm2-test-equal (== (BenchMainRuleCount benchCore) 3) true)
!(mm2-test-equal (== (BenchNoiseStatementCount benchCore) 0) true)
!(mm2-test-equal (BenchTargetProved? benchCore 1 60) true)
!(mm2-test-equal (not (== (BenchPLNKB benchCore) ())) true)
!(mm2-test-equal (== (BenchListCount (BenchPLNAtoms benchCore)) (BenchTrueStatementCount benchCore)) true)
!(BenchGenerate benchNoiseMix (depth 2) (width 2) (paths 1) (noise-factor 1) (backward-ratio 50) (backward-chain-len 3) (forward-chain-len 2))
!(mm2-test-equal (== (BenchTrueStatementCount benchNoiseMix) 7) true)
!(mm2-test-equal (== (BenchNoiseStatementCount benchNoiseMix) 7) true)
!(mm2-test-equal (== (BenchNoiseBackwardRuleCount benchNoiseMix) 3) true)
!(mm2-test-equal (== (BenchNoiseForwardRuleCount benchNoiseMix) 4) true)
!(mm2-test-equal (== (BenchListCount (BenchPLNAtoms benchNoiseMix)) (+ (BenchTrueStatementCount benchNoiseMix) (BenchNoiseStatementCount benchNoiseMix))) true)
!(mm2-test-equal (not (== (collapse (match &kb ((BenchNoiseBackRule benchNoiseMix 1 0) (kb MAIN Nil) (bench-noise-back-meta benchNoiseMix 1 0) (STV 1.0 1.0)) yes)) ())) true)
!(mm2-test-equal (query 100 kb (: (bench-noise-back-head benchNoiseMix 1) (BenchTarget benchNoiseMix 1) $tv)) ())
!(mm2-test-equal (let (: $prf (NoiseDeadEnd benchNoiseMix 4) $_tv) (query 100 kb (: $prf (NoiseDeadEnd benchNoiseMix 4) $tv)) (: $prf (NoiseDeadEnd benchNoiseMix 4) random-tv)) (: ((bench-noise-forward-rule benchNoiseMix 4 2) ((bench-noise-forward-rule benchNoiseMix 4 1) (bench-base-fact benchNoiseMix 1 4))) (NoiseDeadEnd benchNoiseMix 4) random-tv))
!(mm2-test-equal (let (: $prf (NoiseDeadEnd benchNoiseMix 5) $_tv) (query 100 kb (: $prf (NoiseDeadEnd benchNoiseMix 5) $tv)) (: $prf (NoiseDeadEnd benchNoiseMix 5) random-tv)) (: ((bench-noise-forward-rule benchNoiseMix 5 2) ((bench-noise-forward-rule benchNoiseMix 5 1) (bench-base-fact benchNoiseMix 1 1))) (NoiseDeadEnd benchNoiseMix 5) random-tv))
!(BenchGenerate benchPaths3 (depth 2) (width 2) (paths 3) (noise-factor 1) (backward-ratio 50) (backward-chain-len 3) (forward-chain-len 2))
!(mm2-test-equal (== (BenchBaseFactCount benchPaths3) 12) true)
!(mm2-test-equal (== (BenchMainRuleCount benchPaths3) 9) true)
!(mm2-test-equal (== (BenchTrueStatementCount benchPaths3) 21) true)
!(mm2-test-equal (== (BenchNoiseStatementCount benchPaths3) 21) true)
!(mm2-test-equal (and (BenchTargetProved? benchPaths3 1 80) (and (BenchTargetProved? benchPaths3 2 80) (BenchTargetProved? benchPaths3 3 80))) true)
!(mm2-test-equal (let $c (BenchGlobalConf) (and (>= $c 0.45) (<= $c 0.98))) true)
!(mm2-test-equal (== (BenchListCount (collapse (BenchGenerateWithPrint benchNoDupPrint (depth 2) (width 2) (paths 1) (noise-factor 1) (backward-ratio 50) (backward-chain-len 3) (forward-chain-len 2) (print true)))) 1) true)
!(mm2-test-equal (== (BenchTrueStatementCount benchNoDupPrint) 7) true)
!(mm2-test-equal (== (BenchNoiseStatementCount benchNoDupPrint) 7) true)
