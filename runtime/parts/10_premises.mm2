                         $pos-s
                         (product_f64
                           $agg-s
                           $gt-s))
                       (product_f64
                         $neg-s
                         (sub_f64
                           1.0
                           (product_f64
                             $agg-s
                             $gt-s))))
                   (pln_mp_confidence_f64
                       (product_f64
                         $agg-s
                         $gt-s)
                       (pln_and_confidence_f64
                         $agg-s
                         $agg-c
                         $gt-s
                         $gt-c)
                       $pos-s
                       $pos-c
                       $neg-s
                       $neg-c))))))

(exec-template
  (exec 4
        (, (dist-gt2-open
             $g
             (ctv ($pos-s $pos-c) ($neg-s $neg-c))
             ($agg-s $agg-c)
             (ParticleDist $pida $scalea)
             (ParticleDist $pidb $scaleb)
             $proof-id
             $evset)
           (dist-gt2-strength (ParticleDist $pida $scalea) (ParticleDist $pidb $scaleb) $gt-s)
           (dist-confidence (ParticleDist $pida $scalea) $ca)
           (dist-confidence (ParticleDist $pidb $scaleb) $cb))
        (O (- (dist-gt2-open
                $g
                (ctv ($pos-s $pos-c) ($neg-s $neg-c))
