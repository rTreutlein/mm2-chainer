(exec-template
  (exec 3
        (, (wait-premises
             $g
             (compute-plus-ctv-bound ($pos-s $pos-c) ($lhs $rhs $res ($neg-s $neg-c)))
             (pcons $prem pnil)
             ($agg-s $agg-c)
             $proof-id
             $evset)
           (fact $prem ($prem-s $prem-c)))
        (O (- (wait-premises
              $g
              (compute-plus-ctv-bound ($pos-s $pos-c) ($lhs $rhs $res ($neg-s $neg-c)))
              (pcons $prem pnil)
              ($agg-s $agg-c)
              $proof-id
              $evset))
           (pure (compute-plus-checked
                   $verdict
                   $g
                   (ctv ($pos-s $pos-c) ($neg-s $neg-c))
                   ($agg-s $agg-c)
                   ($prem-s $prem-c)
                   $proof-id
                   (pcons (fact-ev (fact-key $prem) $prem) $evset))
                 $verdict
                 (i64_to_string
                   (signum_i64
                     (abs_i64
                       (sub_i64
                         (i64_from_string $res)
                         (sum_i64
                           (i64_from_string $lhs)
                           (i64_from_string $rhs))))))))))

(exec-template
  (exec 4
        (, (compute-plus-checked
             0
             $g
             (ctv ($pos-s $pos-c) ($neg-s $neg-c))
             ($agg-s $agg-c)
             ($prem-s $prem-c)
             $proof-id
             $evset))
        (O (- (compute-plus-checked
