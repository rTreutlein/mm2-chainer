              $g
              (ctv ($pos-s $pos-c) ($neg-s $neg-c))
              ($agg-s $agg-c)
              ($prem-s $prem-c)
              $proof-id
              $evset))
           (pure (open-proof $g $proof-stv $proof-id $evset)
                 $proof-stv
                 (tuple
                   (sum_f64
                       (product_f64
                         $pos-s
                         (product_f64
                           $agg-s
                           $prem-s))
                       (product_f64
                         $neg-s
                         (sub_f64
                           1.0
                           (product_f64
                             $agg-s
                             $prem-s))))
                   (pln_mp_confidence_f64
                       (product_f64
                         $agg-s
                         $prem-s)
                       (pln_and_confidence_f64
                         $agg-s
                         $agg-c
                         $prem-s
                         $prem-c)
                       $pos-s
                       $pos-c
                       $neg-s
                       $neg-c))))))

(exec-template
  (exec 4
        (, (compute-plus-checked 1 $g $rule-stv $agg-stv $prem-stv $proof-id $evset))
        (O (- (compute-plus-checked 1 $g $rule-stv $agg-stv $prem-stv $proof-id $evset)))))

; Distribution Map2 pseudo-premise. The compiler rewrites the conclusion to a
; deterministic result ParticleDist, then this path materializes its weighted
; output pairs from the exported input distribution pairs.
(exec-template
  (exec 4
        (, (wait-premises
             $g
             (dist-map2-ctv (1.0 1.0) (map2 * (ParticleDist $pida $scalea) (ParticleDist $pidb $scaleb) (0.0 1.0)))
             pnil
             $agg-stv
             $proof-id
             $evset))
        (O (- (wait-premises
              $g
              (dist-map2-ctv (1.0 1.0) (map2 * (ParticleDist $pida $scalea) (ParticleDist $pidb $scaleb) (0.0 1.0)))
              pnil
              $agg-stv
              $proof-id
              $evset))
           (+ (dist-map2-active * (ParticleDist $pida $scalea) (ParticleDist $pidb $scaleb)))
           (+ (open-proof $g $agg-stv $proof-id $evset)))))

(exec-template
  (exec 2
        (, (dist-map2-active * (ParticleDist $pida $scalea) (ParticleDist $pidb $scaleb))
           (dist-pair $pida $xa $wa)
           (dist-pair $pidb $xb $wb))
        (O (pure (dist-map2-contrib
                   (dist-map2 * (ParticleDist $pida $scalea) (ParticleDist $pidb $scaleb))
                   (dist-map2-source $xa $xb)
                   $pair)
                 $pair
                 (tuple
                   (product_f64
                       $xa
                       $xb)
                   (product_f64
                       (product_f64
                         $wa
                         $wb)
                       (product_f64
                         $scalea
                         $scaleb)))))))

(exec-template
  (exec 2
        (, (dist-map2-contrib $pid $source ($y $mass)))
        (O (fsum (dist-pair $pid $y $sum) $sum $mass $source))))

; Distribution GreaterThan pseudo-premises.  PeTTa's DistGreaterThanFormula
; scales only the strength by the ParticleDist scale; confidence is derived
; from the underlying pair weights via neff/(neff + 20).
(exec-template
  (exec 4
        (, (wait-premises
             $g
             (dist-gt-ctv ($pos-s $pos-c) (gt (ParticleDist $pid $scale) $threshold ($neg-s $neg-c)))
             pnil
             no-stv
             $proof-id
             $evset))
        (O (- (wait-premises
                $g
                (dist-gt-ctv ($pos-s $pos-c) (gt (ParticleDist $pid $scale) $threshold ($neg-s $neg-c)))
                pnil
                no-stv
                $proof-id
                $evset))
           (+ (dist-stats-active (ParticleDist $pid $scale)))
           (+ (dist-gt-active (ParticleDist $pid $scale) $threshold))
           (+ (dist-gt-open
                $g
                (ctv ($pos-s $pos-c) ($neg-s $neg-c))
                (1.0 1.0)
                (ParticleDist $pid $scale)
                $threshold
                $proof-id
                $evset)))))

(exec-template
  (exec 4
        (, (wait-premises
             $g
             (dist-gt-ctv ($pos-s $pos-c) (gt (ParticleDist $pid $scale) $threshold ($neg-s $neg-c)))
             pnil
             ($agg-s $agg-c)
             $proof-id
             $evset))
        (O (- (wait-premises
                $g
                (dist-gt-ctv ($pos-s $pos-c) (gt (ParticleDist $pid $scale) $threshold ($neg-s $neg-c)))
                pnil
                ($agg-s $agg-c)
                $proof-id
                $evset))
           (+ (dist-stats-active (ParticleDist $pid $scale)))
           (+ (dist-gt-active (ParticleDist $pid $scale) $threshold))
           (+ (dist-gt-open
                $g
                (ctv ($pos-s $pos-c) ($neg-s $neg-c))
                ($agg-s $agg-c)
                (ParticleDist $pid $scale)
                $threshold
                $proof-id
                $evset)))))

(exec-template
  (exec 4
        (, (wait-premises
             $g
             (dist-gt-dist-ctv
               ($pos-s $pos-c)
               (gt2 (ParticleDist $pida $scalea) (ParticleDist $pidb $scaleb) ($neg-s $neg-c)))
