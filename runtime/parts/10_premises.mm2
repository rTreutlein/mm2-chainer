           (+ (dist-stats-active (ParticleDist $pida $scalea)))
           (+ (dist-stats-active (ParticleDist $pidb $scaleb)))
           (+ (dist-gt2-active (ParticleDist $pida $scalea) (ParticleDist $pidb $scaleb)))
