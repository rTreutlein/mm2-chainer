                     $w
                     $w)))))

(exec-template
  (exec 2
        (, (dist-stat-contrib (ParticleDist $pid $scale) $x $w $w2))
        (O (fsum
             (dist-stat-total (ParticleDist $pid $scale) $total)
             $total
             $w
