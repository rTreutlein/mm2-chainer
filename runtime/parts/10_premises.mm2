(exec-template
  (exec 3
        (, (dist-stat-total (ParticleDist $pid $scale) $total)
           (dist-stat-sumsq (ParticleDist $pid $scale) $sumsq))
        (O (pure (dist-confidence (ParticleDist $pid $scale) $confidence)
                 $confidence
                 (div_f64
                     (div_f64
                       (product_f64
                         $total
                         $total)
                       $sumsq)
                     (sum_f64
                       (div_f64
                         (product_f64
                           $total
                           $total)
                         $sumsq)
                       20.0))))))

