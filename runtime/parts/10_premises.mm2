(exec-template
  (exec 4
        (, (dist-gt-open
             $g
             (ctv ($pos-s $pos-c) ($neg-s $neg-c))
             ($agg-s $agg-c)
             (ParticleDist $pid $scale)
             $threshold
             $proof-id
