                       $neg-s
                       $neg-c))))))

; Evidence-aware conjunction adapter.  It carries pool state for same-source
; marginal projections so a query over several projections of one (And ...)
; source counts that source once instead of multiplying/revising its marginals.
(exec-template
  (exec 4
        (, (wait-premises-pool $g pnil (and-pool ($agg-s $agg-c) $evset $parts) $proof-id))
        (O (- (wait-premises-pool $g pnil (and-pool ($agg-s $agg-c) $evset $parts) $proof-id))
           (+ (open-proof $g ($agg-s $agg-c) $proof-id $evset)))))

(exec-template
  (exec 4
        (, (wait-premises-pool $g (pcons $prem $rest) $agg-state $proof-id))
        (O (- (wait-premises-pool $g (pcons $prem $rest) $agg-state $proof-id))
           (+ (wait-premise-pool $g $prem $rest $agg-state $proof-id))
           (+ (, (Goal $prem))))))

(exec-template
  (exec 4
        (, (wait-premise-pool $g $prem $rest $agg-state $proof-id)
           (proved $prem ($prem-s $prem-c) $prem-proof-id $prem-evset))
        (O (- (wait-premise-pool $g $prem $rest $agg-state $proof-id))
           (pure (pool-step $g $rest $proof-id $pool-result)
                 $pool-result
                 (pln_and_pool_acc
                   (' (pool-input $agg-state ($prem-s $prem-c) $prem-evset)))))))

(exec-template
  (exec 4
        (, (pool-step $g $rest $proof-id (pool-advance $next-state)))
        (O (- (pool-step $g $rest $proof-id (pool-advance $next-state)))
           (+ (wait-premises-pool $g $rest $next-state $proof-id)))))

(exec-template
  (exec 4
        (, (pool-step $g $rest $proof-id pool-blocked))
        (O (- (pool-step $g $rest $proof-id pool-blocked)))))

(exec-template
  (exec 4
        (, (wait-premises $g $rule-stv (pcons $prem $rest) $agg-stv $proof-id $evset))
        (O (- (wait-premises $g $rule-stv (pcons $prem $rest) $agg-stv $proof-id $evset))
           (+ (wait-premise $g $rule-stv $prem $rest $agg-stv $proof-id $evset))
           (+ (, (Goal $prem))))))

; The first matched premise seeds the aggregate directly.  Later premises fold
; with PeTTa-compatible AndFormula confidence propagation.
;
; Evidence items identify the premise source only (like PeTTaChainer proof
; names), never its truth value: a re-derivation from the same source must
; overlap the fact's accumulated evidence so the merge stays idempotent
; instead of revising the same evidence in at a new value.
; Runtime lookups use (fact-ev (fact-key fact) fact); compiler-known named
; facts use (fact-ev (proof-id id) fact).
(exec-template
  (exec 4
        (I (BTM (wait-premise $g $rule-stv $prem $rest no-stv $proof-id $evset))
           (one-of
             (positive-fact $prem ($prem-s $prem-c))
             (fact $prem ($prem-s $prem-c))
             (fact $prem (ctvpair ($prem-s $prem-c) $negative))))
        (O (- (wait-premise $g $rule-stv $prem $rest no-stv $proof-id $evset))
           (+ (wait-premises
                $g
                $rule-stv
                $rest
                ($prem-s $prem-c)
                $proof-id
                (pcons (fact-ev (fact-key $prem) $prem) $evset))))))

(exec-template
  (exec 4
        (I (BTM (wait-premise $g $rule-stv $prem $rest ($agg-s $agg-c) $proof-id $evset))
           (one-of
             (positive-fact $prem ($prem-s $prem-c))
             (fact $prem ($prem-s $prem-c))
             (fact $prem (ctvpair ($prem-s $prem-c) $negative))))
        (O (- (wait-premise $g $rule-stv $prem $rest ($agg-s $agg-c) $proof-id $evset))
           (pure (wait-premises
                   $g
                   $rule-stv
                   $rest
                   $next-agg-stv
                   $proof-id
                   (pcons (fact-ev (fact-key $prem) $prem) $evset))
                 $next-agg-stv
                 (tuple
                   (product_f64
                       $agg-s
                       $prem-s)
                   (pln_and_confidence_f64
                       $agg-s
                       $agg-c
                       $prem-s
                       $prem-c))))))

; OrFormula premise fold.  Its confidence is the same propagated product
; variance as AndFormula over complemented strengths, converted back at the
; Or strength point.
(exec-template
  (exec 4
        (, (wait-premises-or $g identity pnil ($agg-s $agg-c) $proof-id $evset))
        (O (- (wait-premises-or $g identity pnil ($agg-s $agg-c) $proof-id $evset))
           (+ (open-proof $g ($agg-s $agg-c) $proof-id $evset)))))

(exec-template
  (exec 4
        (, (wait-premises-or $g $final-kind (pcons $prem $rest) $agg-stv $proof-id $evset))
        (O (- (wait-premises-or $g $final-kind (pcons $prem $rest) $agg-stv $proof-id $evset))
           (+ (wait-premise-or $g $final-kind $prem $rest $agg-stv $proof-id $evset))
           (+ (, (Goal $prem))))))

(exec-template
  (exec 4
        (, (wait-premise-or $g $final-kind $prem $rest no-stv $proof-id $evset)
           (fact $prem ($prem-s $prem-c)))
        (O (- (wait-premise-or $g $final-kind $prem $rest no-stv $proof-id $evset))
           (+ (wait-premises-or
                $g
                $final-kind
                $rest
                ($prem-s $prem-c)
                $proof-id
                (pcons (fact-ev (fact-key $prem) $prem) $evset))))))

(exec-template
  (exec 4
        (, (wait-premise-or $g $final-kind $prem $rest ($agg-s $agg-c) $proof-id $evset)
           (fact $prem ($prem-s $prem-c)))
        (O (- (wait-premise-or $g $final-kind $prem $rest ($agg-s $agg-c) $proof-id $evset))
           (pure (wait-premises-or
                   $g
                   $final-kind
                   $rest
                   $next-agg-stv
                   $proof-id
                   (pcons (fact-ev (fact-key $prem) $prem) $evset))
                 $next-agg-stv
                 (tuple
                   (sub_f64
                       1.0
                       (product_f64
                         (sub_f64 1.0 $agg-s)
                         (sub_f64 1.0 $prem-s)))
                   (pln_and_confidence_f64
                       (sub_f64 1.0 $agg-s)
                       $agg-c
                       (sub_f64 1.0 $prem-s)
                       $prem-c))))))

; Projection rules: the compound head premise's TV is captured into the
; rule-TV slot, then the remaining element premises run through the generic
; premise machinery (seed + AndFormula fold) to produce the evidence TV.
(exec-template
  (exec 4
        (, (wait-head $g (proj $op $proj-id) $head $others $proof-id $evset)
           (fact $head ($head-s $head-c)))
        (O (- (wait-head $g (proj $op $proj-id) $head $others $proof-id $evset))
           (+ (wait-premises
                $g
                (proj $op $proj-id ($head-s $head-c))
                $others
                no-stv
                $proof-id
                (pcons
                  (projection-ev $proj-id $head ($head-s $head-c) $g)
                  (pcons (fact-ev (fact-key $head) $head) $evset)))))))

; AndProjection: element strength = min(1, s_compound / s_evidence),
; confidence = min(c_compound, c_evidence); (0 0) when the evidence
; strength is zero.
(exec-template
  (exec 4
        (, (wait-premises $g (proj and $proj-id ($sab $cab)) pnil ($ev-s $ev-c) $proof-id $evset))
        (O (- (wait-premises $g (proj and $proj-id ($sab $cab)) pnil ($ev-s $ev-c) $proof-id $evset))
           (pure (open-proof $g $proof-stv $proof-id $evset)
                 $proof-stv
                 (tuple
                   (ifnz
                       (eq_f64 $ev-s 0.0)
                       then 0.0
                       else
                       (min_f64
                         (div_f64
                           $sab
                           $ev-s)
                         1.0))
                   (ifnz
                       (eq_f64 $ev-s 0.0)
                       then 0.0
                       else
                       (min_f64
                         $cab
                         $ev-c)))))))

; OrProjection: element strength = clamp((s_compound - s_evidence) /
; (1 - s_evidence), 0, 1); (0 0) when the evidence strength is one.
(exec-template
  (exec 4
        (, (wait-premises $g (proj or $proj-id ($sab $cab)) pnil ($ev-s $ev-c) $proof-id $evset))
        (O (- (wait-premises $g (proj or $proj-id ($sab $cab)) pnil ($ev-s $ev-c) $proof-id $evset))
           (pure (open-proof $g $proof-stv $proof-id $evset)
                 $proof-stv
                 (tuple
                   (ifnz
                       (eq_f64 $ev-s 1.0)
                       then 0.0
                       else
                       (clamp_f64
                         (div_f64
                           (sub_f64
                             $sab
                             $ev-s)
                           (sub_f64
                             1.0
                             $ev-s))
                         0.0
                         1.0))
                   (ifnz
                       (eq_f64 $ev-s 1.0)
                       then 0.0
                       else
                       (min_f64
                         $cab
                         $ev-c)))))))

; AndMarginalProjection: single-premise projection with the marginal count
; heuristic: strength = s_compound, confidence from the count
; s_compound * count(c_compound) pushed back through count-confidence.
(exec-template
  (exec 4
        (, (wait-premises $g (proj marg $proj-id ($sab $cab)) pnil no-stv $proof-id $evset))
        (O (- (wait-premises $g (proj marg $proj-id ($sab $cab)) pnil no-stv $proof-id $evset))
           (pure (open-proof $g $proof-stv $proof-id $evset)
                 $proof-stv
                 (tuple
                   $sab
                   (ifnz
                       (lte_f64 $cab 0.0)
                       then 0.0
                       else
                       (div_f64
                         (product_f64
                           $sab
                           (div_f64
                             $cab
                             (sub_f64
                               1.0
                               (min_f64
                                 $cab
                                 0.9999))))
                         (sum_f64
                           (product_f64
                             $sab
                             (div_f64
                               $cab
                               (sub_f64
                                 1.0
                                 (min_f64
                                   $cab
                                   0.9999))))
                           1.0))))))))

; Total-implication rules (kind (proj ctvpair)) conclude a contextual TV
; assembled structurally from their two premises: the positive-context
; conclusion's TV is captured as the head, the negative-context conclusion's
; TV arrives as the premise aggregate. The pair bypasses open-proof --
; revision machinery is (s c)-only, and ctvpair facts are one-shot query
; conclusions.
(exec-template
  (exec 4
        (, (wait-premises $g (proj ctvpair $proj-id ($ps $pc)) pnil ($ns $nc) $proof-id $evset))
        (O (- (wait-premises $g (proj ctvpair $proj-id ($ps $pc)) pnil ($ns $nc) $proof-id $evset))
           (+ (fact $g (ctvpair ($ps $pc) ($ns $nc))))
           (+ (proved $g (ctvpair ($ps $pc) ($ns $nc)) $proof-id $evset)))))

; NotFormula: single-premise negation adapter, (s c) -> (1-s c).
(exec-template
  (exec 4
        (, (wait-premises $g (proj not $proj-id ($s $c)) pnil no-stv $proof-id $evset))
        (O (- (wait-premises $g (proj not $proj-id ($s $c)) pnil no-stv $proof-id $evset))
           (pure (open-proof $g $proof-stv $proof-id $evset)
                 $proof-stv
                 (tuple
                   (sub_f64 1.0 $s)
                   $c)))))

; Inverse rules (kind inv) apply PeTTa's CTVInversionFormula at fire time:
; the original rule's positive branch is inverted through the base rates of
; its antecedent ($ante) and consequent ($cons), and the inverted CTV is
; pushed through modus ponens with the consequent witness ($premise TV).
; The negative inverted branch reuses the same ops with complemented
; consequent-rate/strength arguments.
;
; Inversion can be rejected (no base-rate evidence yet, or marginals outside
; the Frechet bounds), so the attempt does not consume the wait record: it
; emits an (inv-checked ($tag $s $c) ...) verdict each round. An accepted
; verdict consumes both and opens the proof; a rejected verdict is dropped
; and the attempt retries as the base rates evolve.
(exec-template
  (exec 4
        (, (wait-premises $g (inv ($pos-s $pos-c) (brpat $ante $cons)) pnil ($premise-s $premise-c) $proof-id $evset)
           (base-rate $ante ($ante-s $ante-c))
           (base-rate $cons ($cons-s $cons-c)))
        (O (pure (inv-checked $verdict $g $proof-id $evset)
                 $verdict
                 (tuple
                   (ifnz
                     (pln_inversion_valid_f64
                         $ante-s
                         $ante-c
                         $cons-s
                         $cons-c
                         $pos-s)
                     then inv-valid
                     else inv-invalid)
                   (sum_f64
                       (product_f64
                         (pln_inv_strength_f64
                           $ante-s
                           $cons-s
                           $pos-s)
                         $premise-s)
                       (product_f64
                         (pln_inv_strength_f64
                           $ante-s
                           (sub_f64 1.0 $cons-s)
                           (sub_f64 1.0 $pos-s))
                         (sub_f64
                           1.0
                           $premise-s)))
                   (pln_mp_confidence_f64
                       $premise-s
                       $premise-c
                       (pln_inv_strength_f64
                         $ante-s
                         $cons-s
                         $pos-s)
                       (pln_inv_confidence_f64
                         $ante-s
                         $ante-c
                         $cons-s
                         $cons-c
                         $pos-s
                         $pos-c)
                       (pln_inv_strength_f64
                         $ante-s
                         (sub_f64 1.0 $cons-s)
                         (sub_f64 1.0 $pos-s))
                       (pln_inv_confidence_f64
                         $ante-s
                         $ante-c
                         (sub_f64 1.0 $cons-s)
                         $cons-c
                         (sub_f64 1.0 $pos-s)
                         $pos-c)))))))

(exec-template
  (exec 5
        (, (inv-checked (inv-valid $proof-s $proof-c) $g $proof-id $evset)
           (wait-premises $g (inv $pos (brpat $ante $cons)) pnil $agg $proof-id $evset))
        (O (- (inv-checked (inv-valid $proof-s $proof-c) $g $proof-id $evset))
           (- (wait-premises $g (inv $pos (brpat $ante $cons)) pnil $agg $proof-id $evset))
           (+ (open-proof $g ($proof-s $proof-c) $proof-id $evset)))))

(exec-template
  (exec 5
        (, (inv-checked (inv-invalid $proof-s $proof-c) $g $proof-id $evset))
        (O (- (inv-checked (inv-invalid $proof-s $proof-c) $g $proof-id $evset)))))
