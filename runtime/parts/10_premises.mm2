                (ctv ($pos-s $pos-c) ($neg-s $neg-c))
                ($agg-s $agg-c)
                (ParticleDist $pida $scalea)
                (ParticleDist $pidb $scaleb)
                $proof-id
                $evset)))))

(exec-template
  (exec 2
        (, (dist-stats-active (ParticleDist $pid $scale))
           (dist-pair $pid $x $w))
        (O (pure (dist-stat-contrib (ParticleDist $pid $scale) $x $w $w2)
                 $w2
