; Multi-premise rules open one concrete frontier premise at a time. Shared
; variables are instantiated by earlier matches before later premises are opened.
; STVs are carried as packed pairs: (strength confidence).
; Rule application is PeTTa's CTVModusPonensFormula: the aggregated premise
; TV is pushed through the rule's contextual TV (positive and negative
; branches) with idealized second-order confidence propagation.
(exec-template
  (exec 4
        (, (wait-premises $g (ctv ($pos-s $pos-c) ($neg-s $neg-c)) pnil ($premise-s $premise-c) $proof-id $evset))
        (O (- (wait-premises $g (ctv ($pos-s $pos-c) ($neg-s $neg-c)) pnil ($premise-s $premise-c) $proof-id $evset))
           (pure (open-proof $g $proof-stv $proof-id $evset)
                 $proof-stv
                 (tuple
                   (sum_f64
                       (product_f64
                         $pos-s
                         $premise-s)
                       (product_f64
                         $neg-s
                         (sub_f64
                           1.0
                           $premise-s)))
                   (pln_mp_confidence_f64
                       $premise-s
                       $premise-c
                       $pos-s
                       $pos-c
                       $neg-s
                       $neg-c))))))

; Fused TV pipelines keep NotFormula attached to the value it transforms,
; rather than making it look like a property of the CTV.  The positive CTV
; branch remains the first field so the generic rule scheduler can read its
; confidence without a pipeline-specific scheduling template.
;
; premise-not complements the premise aggregate before pushing it through
; CTVModusPonensFormula.
(exec-template
  (exec 4
        (, (wait-premises
             $g
             (tv-pipeline ($pos-s $pos-c) (premise-not ($neg-s $neg-c)))
             pnil
             ($premise-s $premise-c)
             $proof-id
             $evset))
        (O (- (wait-premises
                $g
                (tv-pipeline ($pos-s $pos-c) (premise-not ($neg-s $neg-c)))
                pnil
                ($premise-s $premise-c)
                $proof-id
                $evset))
           (pure (open-proof $g $proof-stv $proof-id $evset)
                 $proof-stv
                 (tuple
                   (sum_f64
                       (product_f64
                         $pos-s
                         (sub_f64
                           1.0
                           $premise-s))
                       (product_f64
                         $neg-s
                         $premise-s))
                   (pln_mp_confidence_f64
                       (sub_f64 1.0 $premise-s)
                       $premise-c
                       $pos-s
                       $pos-c
                       $neg-s
                       $neg-c))))))

; A fused TV pipeline with a post-transform of NotFormula applies modus ponens
; first, then complements the conclusion strength while preserving confidence.
(exec-template
  (exec 4
        (, (wait-premises
             $g
             (tv-pipeline ($pos-s $pos-c) (conclusion-not ($neg-s $neg-c)))
             pnil
             ($premise-s $premise-c)
             $proof-id
             $evset))
        (O (- (wait-premises
                $g
                (tv-pipeline ($pos-s $pos-c) (conclusion-not ($neg-s $neg-c)))
                pnil
                ($premise-s $premise-c)
                $proof-id
                $evset))
           (pure (open-proof $g $proof-stv $proof-id $evset)
                 $proof-stv
                 (tuple
                   (sub_f64
                       1.0
                       (sum_f64
                         (product_f64
                           $pos-s
                           $premise-s)
                         (product_f64
                           $neg-s
                           (sub_f64
                             1.0
                             $premise-s))))
                   (pln_mp_confidence_f64
                       $premise-s
                       $premise-c
                       $pos-s
                       $pos-c
                       $neg-s
                       $neg-c))))))

; Plain STV rules first derive their negative branch from the current base
; rates of the rule's antecedent and consequent patterns (PeTTaChainer's
; ImplicationCTVFormula):
;
;   neg strength   = NegativeBranchStrength(ante-s, cons-s, rule-s)
;   neg confidence = 0.25 * min(ante-c, cons-c, rule-c)
(exec-template
  (exec 4
        (, (wait-premises $g (stv ($rule-s $rule-c) (brpat $ante $cons)) pnil ($premise-s $premise-c) $proof-id $evset)
           (base-rate $ante ($ante-s $ante-c))
           (base-rate $cons ($cons-s $cons-c)))
        (O (- (wait-premises $g (stv ($rule-s $rule-c) (brpat $ante $cons)) pnil ($premise-s $premise-c) $proof-id $evset))
           (pure (open-proof $g $proof-stv $proof-id $evset)
                 $proof-stv
                 (tuple
                   (sum_f64
                       (product_f64
                         $rule-s
                         $premise-s)
                       (product_f64
                         (ifnz
                           (gte_f64
                             $ante-s
                             1.0)
                           then
                           $cons-s
                           else
                           (clamp_f64
                             (div_f64
                               (sub_f64
                                 $cons-s
                                 (product_f64
                                   $ante-s
                                   $rule-s))
                               (sub_f64
                                 1.0
                                 $ante-s))
                             0.0
                             1.0))
                         (sub_f64
                           1.0
                           $premise-s)))
                   (pln_mp_confidence_f64
                       $premise-s
                       $premise-c
                       $rule-s
                       $rule-c
                       (ifnz
                         (gte_f64
                           $ante-s
                           1.0)
                         then
                         $cons-s
                         else
                         (clamp_f64
                           (div_f64
                             (sub_f64
                               $cons-s
                               (product_f64
                                 $ante-s
                                 $rule-s))
                             (sub_f64
                               1.0
                               $ante-s))
                           0.0
                           1.0))
                       (product_f64
                         0.25
                         (min_f64
                           $ante-c
                           $cons-c
                           $rule-c))))))))

(exec-template
  (exec 4
        (, (wait-premises $g identity pnil $agg-stv $proof-id $evset))
        (O (- (wait-premises $g identity pnil $agg-stv $proof-id $evset))
           (+ (open-proof $g $agg-stv $proof-id $evset)))))

; TotalEvidence case helpers store the computed TV in the evidence term as well
; as in the fact value, matching the FoldAll extract-value pattern.
(exec-template
  (exec 4
        (, (wait-premises
             ((kb $ctx $vars) (TotalEvidence $case $p1 $p2 $x $case-tv))
             (total-evidence-case $case)
             pnil
             ($case-s $case-c)
             $proof-id
             $evset))
        (O (- (wait-premises
                ((kb $ctx $vars) (TotalEvidence $case $p1 $p2 $x $case-tv))
                (total-evidence-case $case)
                pnil
                ($case-s $case-c)
                $proof-id
                $evset))
           (+ (open-proof
	                ((kb $ctx $vars) (TotalEvidence $case $p1 $p2 $x ($case-s $case-c)))
	                ($case-s $case-c)
	                $proof-id
	                $evset)))))

; First-premise NotFormula support. After complementing the first premise TV,
; continue with the normal AndFormula premise fold over the remaining premises.
(exec-template
  (exec 4
        (, (wait-premise $g $rule-stv $prem $rest not-stv $proof-id $evset)
           (fact $prem ($prem-s $prem-c)))
        (O (- (wait-premise $g $rule-stv $prem $rest not-stv $proof-id $evset))
           (pure (wait-premises
                   $g
                   $rule-stv
                   $rest
                   ($not-s $prem-c)
                   $proof-id
                   (pcons (fact-ev (fact-key $prem) $prem) $evset))
                 $not-s
                 (sub_f64 1.0 $prem-s)))))

; Once the antecedent of a TotalEvidence aggregate is known, open the FoldAll
; evidence pattern and stream every matching evidence case into the aggregate
; sink.
(exec-template
  (exec 4
        (, (wait-total-evidence
             $g
             $proof-id
             $prem
             $p1
             $p2
             $fold-scope
             $evset)
           (fact $prem ($ante-s $ante-c)))
        (O (- (wait-total-evidence
                $g
                $proof-id
                $prem
                $p1
                $p2
                $fold-scope
                $evset))
           (+ (total-evidence-active
                $g
                $proof-id
                ($ante-s $ante-c)
                $p1
                $p2
                $fold-scope
                (pcons (fact-ev (fact-key $prem) $prem) $evset)))
           (+ (, (Goal ($fold-scope (TotalEvidence $case $p1 $p2 $x $case-tv))))))))

(exec-template
  (exec 2
        (, (total-evidence-active
             $g
             $proof-id
             $ante-stv
             $p1
             $p2
             (kb $fold-ctx $fold-vars)
             $ante-evset)
           (fact
             ((kb $fold-ctx $fold-vars) (TotalEvidence $case $p1 $p2 $x ($case-s $case-c)))
             ($case-s $case-c))
           (fact-evidence
             ((kb $fold-ctx $fold-vars) (TotalEvidence $case $p1 $p2 $x ($case-s $case-c)))
             ($case-s $case-c)
             $case-evset)
           (proved
             ((kb $fold-ctx $fold-vars) (TotalEvidence $case $p1 $p2 $x ($case-s $case-c)))
             ($case-s $case-c)
             $case-proof-id
             $case-evset))
        (O (total-evidence-mp
             $g
             $proof-id
             $ante-stv
             $p1
             $p2
             $case
             ($case-s $case-c)
             $case-proof-id
             $case-evset
             $ante-evset))))

; Query-compound Compute + pseudo-premise. PeTTa counts the CPU result as
; certain evidence, but the arithmetic output must constrain the following
; real premise. Fold factual premises before the compute point normally, then
; keep a special bound state so the final premise match can gate proof opening
; on lhs + rhs = result.
(exec-template
  (exec 3
        (, (wait-premises
             $g
             (compute-plus-ctv ($pos-s $pos-c) ($lhs $rhs $res ($neg-s $neg-c)))
             (pcons $prem (pcons $next (pcons $more $rest)))
             no-stv
             $proof-id
             $evset)
           (fact $prem ($prem-s $prem-c)))
        (O (- (wait-premises
              $g
              (compute-plus-ctv ($pos-s $pos-c) ($lhs $rhs $res ($neg-s $neg-c)))
              (pcons $prem (pcons $next (pcons $more $rest)))
              no-stv
              $proof-id
              $evset))
           (+ (wait-premises
                $g
                (compute-plus-ctv ($pos-s $pos-c) ($lhs $rhs $res ($neg-s $neg-c)))
                (pcons $next (pcons $more $rest))
                ($prem-s $prem-c)
                $proof-id
                (pcons (fact-ev (fact-key $prem) $prem) $evset))))))

(exec-template
  (exec 3
        (, (wait-premises
             $g
             (compute-plus-ctv ($pos-s $pos-c) ($lhs $rhs $res ($neg-s $neg-c)))
             (pcons $prem (pcons $next (pcons $more $rest)))
             ($agg-s $agg-c)
             $proof-id
             $evset)
           (fact $prem ($prem-s $prem-c)))
        (O (- (wait-premises
              $g
              (compute-plus-ctv ($pos-s $pos-c) ($lhs $rhs $res ($neg-s $neg-c)))
              (pcons $prem (pcons $next (pcons $more $rest)))
              ($agg-s $agg-c)
              $proof-id
              $evset))
           (pure (wait-premises
                   $g
                   (compute-plus-ctv ($pos-s $pos-c) ($lhs $rhs $res ($neg-s $neg-c)))
                   (pcons $next (pcons $more $rest))
                   $next-agg-stv
                   $proof-id
                   (pcons (fact-ev (fact-key $prem) $prem) $evset))
                 $next-agg-stv
                 (tuple
                   (product_f64
                       $agg-s
                       $prem-s)
                   (pln_and_confidence_f64
                       $agg-s
                       $agg-c
                       $prem-s
                       $prem-c))))))

(exec-template
  (exec 3
        (, (wait-premises
             $g
             (compute-plus-ctv ($pos-s $pos-c) ($lhs $rhs $res ($neg-s $neg-c)))
             (pcons $prem (pcons $next pnil))
             no-stv
             $proof-id
             $evset)
           (fact $prem ($prem-s $prem-c)))
        (O (- (wait-premises
              $g
              (compute-plus-ctv ($pos-s $pos-c) ($lhs $rhs $res ($neg-s $neg-c)))
              (pcons $prem (pcons $next pnil))
              no-stv
              $proof-id
              $evset))
           (pure (wait-premises
                   $g
                   (compute-plus-ctv-bound ($pos-s $pos-c) ($lhs $rhs $res ($neg-s $neg-c)))
                   (pcons $next pnil)
                   ($prem-s $cpu-agg-c)
                   $proof-id
                   (pcons (fact-ev (fact-key $prem) $prem) $evset))
                 $cpu-agg-c
                 (pln_and_confidence_f64
                     $prem-s
                     $prem-c
                     1.0
                     1.0)))))

(exec-template
  (exec 3
        (, (wait-premises
             $g
             (compute-plus-ctv ($pos-s $pos-c) ($lhs $rhs $res ($neg-s $neg-c)))
             (pcons $prem (pcons $next pnil))
             ($agg-s $agg-c)
             $proof-id
             $evset)
           (fact $prem ($prem-s $prem-c)))
        (O (- (wait-premises
              $g
              (compute-plus-ctv ($pos-s $pos-c) ($lhs $rhs $res ($neg-s $neg-c)))
              (pcons $prem (pcons $next pnil))
              ($agg-s $agg-c)
              $proof-id
              $evset))
           (pure (wait-premises
                   $g
                   (compute-plus-ctv-bound ($pos-s $pos-c) ($lhs $rhs $res ($neg-s $neg-c)))
                   (pcons $next pnil)
                   $cpu-agg-stv
                   $proof-id
                   (pcons (fact-ev (fact-key $prem) $prem) $evset))
                 $cpu-agg-stv
