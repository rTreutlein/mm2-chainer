; Reduced STV-aware rule set for merge experiments.
; Two distinct Dog -> Animal proofs should revise into one stronger Animal fact.
(ruleN (Pet $x) dog-pet (ctv (0.8 0.7) (0.0 1.0)) (pcons (Dog $x) pnil))
(ruleN (Animal $x) mammal-animal (ctv (0.9 0.6) (0.0 1.0)) (pcons (Mammal $x) pnil))
(ruleN (Mammal $x) dog-mammal (ctv (0.9 0.6) (0.0 1.0)) (pcons (Dog $x) pnil))
(ruleN (Animal $x) pet-animal (ctv (0.7 0.5) (0.0 1.0)) (pcons (Pet $x) pnil))
(ruleN (Animal $x) creature-animal (ctv (0.4 0.2) (0.0 1.0)) (pcons (Creature $x) pnil))
