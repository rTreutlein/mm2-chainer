; Reduced STV-aware rule set for merge experiments.
; Two distinct Dog -> Animal proofs should revise into one stronger Animal fact.
(ruleN (Pet $x) 0.8 0.7 (pcons (Dog $x) pnil))
(ruleN (Animal $x) 0.9 0.6 (pcons (Mammal $x) pnil))
(ruleN (Mammal $x) 0.9 0.6 (pcons (Dog $x) pnil))
(ruleN (Animal $x) 0.7 0.5 (pcons (Pet $x) pnil))
(ruleN (Animal $x) 0.4 0.2 (pcons (Creature $x) pnil))
